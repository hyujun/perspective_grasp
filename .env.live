_PG_REPO="$( cd "$( dirname "${BASH_SOURCE[0]:-$0}" )" && pwd )"
_PG_WS="$( cd "${_PG_REPO}/../.." && pwd )"

source /opt/ros/jazzy/setup.bash
[ -f "${_PG_WS}/install/setup.bash" ] && source "${_PG_WS}/install/setup.bash"

export RMW_IMPLEMENTATION=rmw_cyclonedds_cpp
export CYCLONEDDS_URI="file://${_PG_REPO}/packages/bringup/perception_bringup/config/cyclonedds_localhost.xml"

cd "${_PG_WS}"
echo "[pg-live] ws=${_PG_WS}  rmw=${RMW_IMPLEMENTATION}"
