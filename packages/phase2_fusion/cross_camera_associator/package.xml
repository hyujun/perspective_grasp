<?xml version="1.0"?>
<?xml-model href="http://download.ros.org/schema/package_format3.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>
<package format="3">
  <name>cross_camera_associator</name>
  <version>0.1.0</version>
  <description>Cross-camera object association using Hungarian algorithm with globally consistent IDs</description>
  <maintainer email="hyujun@todo.todo">hyujun</maintainer>
  <license>Apache-2.0</license>

  <buildtool_depend>ament_cmake</buildtool_depend>

  <depend>rclcpp</depend>
  <depend>tf2_ros</depend>
  <depend>tf2_eigen</depend>
  <depend>perception_msgs</depend>
  <depend>diagnostic_msgs</depend>
  <depend>eigen</depend>

  <exec_depend>perception_launch_utils</exec_depend>

  <test_depend>ament_cmake_gtest</test_depend>

  <export>
    <build_type>ament_cmake</build_type>
  </export>
</package>
