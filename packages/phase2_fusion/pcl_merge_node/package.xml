<?xml version="1.0"?>
<?xml-model href="http://download.ros.org/schema/package_format3.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>
<package format="3">
  <name>pcl_merge_node</name>
  <version>0.1.0</version>
  <description>Merges point clouds from multiple eye-to-hand cameras into a single unified cloud</description>
  <maintainer email="junho@todo.todo">junho</maintainer>
  <license>Apache-2.0</license>

  <buildtool_depend>ament_cmake</buildtool_depend>

  <depend>rclcpp</depend>
  <depend>sensor_msgs</depend>
  <depend>tf2_ros</depend>
  <depend>tf2_sensor_msgs</depend>
  <depend>pcl_conversions</depend>
  <depend>message_filters</depend>
  <depend>diagnostic_msgs</depend>
  <depend>libpcl-all-dev</depend>

  <exec_depend>perception_launch_utils</exec_depend>

  <test_depend>ament_cmake_gtest</test_depend>

  <export>
    <build_type>ament_cmake</build_type>
  </export>
</package>
